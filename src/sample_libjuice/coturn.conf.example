# Coturn configuration example for P2P signaling (libjuice + coturn).
# Copy to /etc/turnserver.conf or use: turnserver -c /path/to/coturn.conf
#
# For same-LAN testing use your LAN IP. For cross-network NAT use your public IP.
# For localhost-only testing use 127.0.0.1.

realm=local
listening-ip=0.0.0.0
external-ip=<REPLACE_WITH_YOUR_IP>
listening-port=3478
min-port=10000
max-port=20000
lt-cred-mech
user=juice_demo:juice_password
fingerprint
verbose

# Optional: TURN over TCP for UDP-blocked networks (RFC 5766/8656)
# tls-listening-port=5349
# listening-port=3478
